{
  "swagger": "2.0",
  "info": {
    "title": "Cooking Merrill(y) API",
    "description": "API documentation for the Cooking Merrill(y) project",
    "version": "1.0.0"
  },
  "host": "cooking-merrilly.onrender.com",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "General"
        ],
        "summary": "API health check",
        "description": "Returns a simple message confirming the API is running.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/recipes/": {
      "get": {
        "tags": [
          "Recipes"
        ],
        "summary": "Get all recipes",
        "description": "Returns all public recipes.",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Recipes"
        ],
        "summary": "Create a new recipe",
        "description": "Creates a new recipe.",
        "parameters": [
          {
            "name": "recipe",
            "in": "body",
            "required": true,
            "description": "Recipe data",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "example": "Hummus"
                },
                "description": {
                  "type": "string",
                  "example": "Quick homemade hummus with optional sweet or spicy additions."
                },
                "ingredients": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "type": "string",
                        "example": "Dates"
                      },
                      "optional": {
                        "type": "boolean",
                        "example": true
                      }
                    }
                  }
                },
                "steps": {
                  "type": "array",
                  "example": [
                    "Mix all ingredients together.",
                    "Adjust measurements to taste."
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "tags": {
                  "type": "array",
                  "example": [
                    "dip",
                    "mediterranean",
                    "sauce",
                    "dairy-free",
                    "vegan"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "prepTimeMinutes": {
                  "type": "number",
                  "example": 5
                },
                "cookTimeMinutes": {
                  "type": "number",
                  "example": 0
                },
                "yield": {
                  "type": "string",
                  "example": "Serves 4–6"
                },
                "pairings": {
                  "type": "string",
                  "example": "Serve with pita, veggies, or as a side to gyros."
                },
                "variations": {
                  "type": "array",
                  "example": [],
                  "items": {}
                },
                "isPublic": {
                  "type": "boolean",
                  "example": true
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/recipes/hidden": {
      "get": {
        "tags": [
          "Recipes"
        ],
        "summary": "Get hidden recipes",
        "description": "Returns recipes where isPublic is false.",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/recipes/{id}": {
      "get": {
        "tags": [
          "Recipes"
        ],
        "summary": "Get recipe by ID",
        "description": "Returns a recipe by its MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Recipe ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Recipes"
        ],
        "summary": "Update a recipe",
        "description": "Updates an existing recipe by ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Recipe ID"
          },
          {
            "name": "recipe",
            "in": "body",
            "required": true,
            "description": "Updated recipe data (partial or full)",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "example": "Updated Hummus Title"
                },
                "description": {
                  "type": "string",
                  "example": "Optional updated description"
                },
                "ingredients": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "type": "string",
                        "example": "8 oz store-bought hummus"
                      }
                    }
                  }
                },
                "steps": {
                  "type": "array",
                  "example": [
                    "Mix all ingredients together."
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "tags": {
                  "type": "array",
                  "example": [
                    "dip",
                    "updated"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "isPublic": {
                  "type": "boolean",
                  "example": true
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Recipes"
        ],
        "summary": "Delete a recipe",
        "description": "Deletes a recipe by ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/recipes/tag/{tag}": {
      "get": {
        "tags": [
