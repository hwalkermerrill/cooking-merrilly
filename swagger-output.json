                },
                "description": {
                  "type": "string",
                  "example": "Test - Fettuccine pasta finished in Alfredo sauce and topped with sliced strip steak."
                },
                "recipeIds": {
                  "type": "array",
                  "example": [
                    "60f7c2b5e1a4c12a34abcd12",
                    "60f7c2b5e1a4c12a34abcd34"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "assemblySteps": {
                  "type": "array",
                  "example": [
                    "Prepare Fettuccine Pasta according to its recipe.",
                    "Prepare Alfredo Sauce according to its recipe.",
                    "Prepare Strip Steak for Alfredo and slice.",
                    "Combine with computer chips and serve."
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "tags": {
                  "type": "array",
                  "example": [
                    "test",
                    "pasta",
                    "alfredo",
                    "cpu",
                    "italian"
                  ],
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
